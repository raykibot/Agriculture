<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.luo.share.mapper.MachineryMapper">

    <resultMap id="data" type="com.luo.share.model.vo.MachineryVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="brand" column="brand"/>
        <result property="model" column="model"/>
        <result property="images" column="images"/>
        <result property="categoryId" column="category_id"/>
        <result property="price" column="price"/>
        <result property="deposit" column="deposit"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="avgRating" column="avg_rating"/>

        <result property="parameters" column="parameters"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
    </resultMap>


    <select id="selectSimpleList" resultMap="data">
        SELECT id, name, brand, price, images, status, category_id
        FROM machinery
        <where>
            status != 2 <if test="categoryId != null and categoryId > 0">
            AND category_id = #{categoryId}
        </if>

            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="selectRandomFromEachCategory" resultType="com.luo.share.model.vo.MachineryVO">
        SELECT id, name, brand, price, images, status
        FROM (
                 SELECT id, name, brand, price, images, status,
                        ROW_NUMBER() OVER(PARTITION BY category_id ORDER BY RAND()) as rn
                 FROM machinery
                 WHERE status != 2 -- 排除维护中
             ) tmp
        WHERE rn = 1
    </select>



    <select id="selectListByCategory" resultType="com.luo.share.model.vo.MachineryVO">
        SELECT id, name, brand, price, images, status
        FROM machinery
        WHERE status != 2 <if test="categoryId != null and categoryId > 0">
        AND category_id = #{categoryId}
    </if>
        ORDER BY create_time DESC
    </select>
</mapper>